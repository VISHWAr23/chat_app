# Backend Environment Variables
# Copy this to Vercel project settings

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chat_db
REDIS_URL=redis://username:password@host.redis.cloud:port

# CORS (set this to your frontend Vercel domain)
CORS_ORIGIN=https://your-frontend.vercel.app

# Node environment
NODE_ENV=production

# Port (Vercel sets this automatically, but you can override)
PORT=3000
